```gitignore
# Python virtual environment
myenv/
venv/

# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Environment variables and secrets
.env

# IDE settings
.vscode/
.idea/

# Operating system files
.DS_Store
Thumbs.db

# Jupyter notebooks
.ipynb_checkpoints/

# Build and distribution files
build/
dist/
*.egg-info/

# Test and coverage files
.pytest_cache/
.coverage
htmlcov/

# Logs generated during development
*.log
```
